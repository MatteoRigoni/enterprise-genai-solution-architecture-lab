@page "/evaluations"
@rendermode InteractiveServer
@using Icons = Microsoft.FluentUI.AspNetCore.Components.Icons
@using Microsoft.FluentUI.AspNetCore.Components
@using AiSa.Host.Components.Dashboard

<PageTitle>Evaluations</PageTitle>

<div class="page-content">
    @if (!heroDismissed)
    {
        <div class="surface-hero">
            <div class="hero-header">
                <h1 class="text-title text-title-gradient">Evaluations</h1>
                <FluentButton Appearance="Appearance.Stealth"
                             OnClick="DismissHero"
                             Title="Dismiss"
                             class="hero-dismiss-button">
                    <FluentIcon Value="@(new Icons.Regular.Size20.Dismiss())" />
                </FluentButton>
            </div>
            <p class="text-body">Monitor RAG quality over time. Run a smoke eval to measure answered rate, citation accuracy, hallucination rate, and latency against the versioned eval dataset.</p>
        </div>
    }

    <!-- Run Eval Section -->
    <div class="dashboard-section @(isRunning ? "eval-run-section-busy" : "")">
        <div class="page-section-header">
            <h2 class="text-section">Smoke Evaluation</h2>
            <FluentButton Appearance="Appearance.Accent"
                         OnClick="RunSmokeEval"
                         disabled="@isRunning"
                         Loading="@isRunning"
                         class="btn-toolbar-end"
                         IconStart="@(new Icons.Regular.Size16.ArrowSync())"
                         Title="Run smoke evaluation">
                Run Smoke Eval
            </FluentButton>
        </div>
        <p class="text-body eval-description">Runs the first 5 questions from the base dataset in-process and writes a report to <code>eval/reports/</code>.</p>
    </div>

    @if (latestReport == null && !isRunning)
    {
        <div class="surface-card empty-state-card">
            <div class="empty-state">
                <div class="empty-state-icon">
                    <FluentIcon Value="@(new Icons.Regular.Size48.Document())" />
                </div>
                <h3 class="empty-state-title">No evaluation reports yet</h3>
                <p class="empty-state-text">Run a smoke eval to get started. Results will appear here with metric indicators and a report summary.</p>
            </div>
        </div>
    }

    @if (latestReport != null)
    {
        <!-- Report Summary -->
        <div class="dashboard-section">
            <h2 class="text-section spacing-group">Latest Report</h2>
            <div class="surface-card report-summary-card">
                <div class="report-meta">
                    <div class="meta-item">
                        <FluentIcon Value="@(new Icons.Regular.Size16.DocumentMultiple())" />
                        <span class="meta-label">Dataset</span>
                        <span>@latestReport.DatasetName v@(latestReport.DatasetVersion)</span>
                    </div>
                    <div class="meta-item">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Clock())" />
                        <span class="meta-label">Run at</span>
                        <span>@latestReport.RunTimestamp.LocalDateTime.ToString("yyyy-MM-dd HH:mm")</span>
                    </div>
                    <div class="meta-item">
                        <FluentIcon Value="@(new Icons.Regular.Size16.Timer())" />
                        <span class="meta-label">Duration</span>
                        <span>@((latestReport.RunDurationMs / 1000.0).ToString("F1"))s</span>
                    </div>
                    <div class="meta-item">
                        <FluentIcon Value="@(new Icons.Regular.Size16.NumberSymbol())" />
                        <span class="meta-label">Questions</span>
                        <span>@latestReport.Metrics.TotalQuestions</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Metrics Cards -->
        <div class="dashboard-section">
            <h2 class="text-section spacing-group">Metrics</h2>
            <div class="metrics-grid">

                <div class="metric-card surface-card">
                    <div class="metric-status-bar @GetMetricStatus("answered", latestReport.Metrics.AnsweredRate)"></div>
                    <div class="metric-icon">
                        <FluentIcon Value="@(new Icons.Regular.Size24.CheckmarkCircle())" />
                    </div>
                    <div class="metric-content">
                        <div class="metric-label">Answered Rate</div>
                        <div class="metric-value @GetMetricStatus("answered", latestReport.Metrics.AnsweredRate)">
                            @((latestReport.Metrics.AnsweredRate * 100).ToString("F0"))%
                        </div>
                        <div class="metric-threshold">Target ≥ 80%</div>
                    </div>
                </div>

                <div class="metric-card surface-card">
                    <div class="metric-status-bar @GetMetricStatus("citation", latestReport.Metrics.CitationPresenceRate)"></div>
                    <div class="metric-icon">
                        <FluentIcon Value="@(new Icons.Regular.Size24.Link())" />
                    </div>
                    <div class="metric-content">
                        <div class="metric-label">Citation Presence</div>
                        <div class="metric-value @GetMetricStatus("citation", latestReport.Metrics.CitationPresenceRate)">
                            @((latestReport.Metrics.CitationPresenceRate * 100).ToString("F0"))%
                        </div>
                        <div class="metric-threshold">Target ≥ 70%</div>
                    </div>
                </div>

                <div class="metric-card surface-card">
                    <div class="metric-status-bar @GetMetricStatus("accuracy", latestReport.Metrics.CitationAccuracyRate)"></div>
                    <div class="metric-icon">
                        <FluentIcon Value="@(new Icons.Regular.Size24.DocumentCheckmark())" />
                    </div>
                    <div class="metric-content">
                        <div class="metric-label">Citation Accuracy</div>
                        <div class="metric-value @GetMetricStatus("accuracy", latestReport.Metrics.CitationAccuracyRate)">
                            @((latestReport.Metrics.CitationAccuracyRate * 100).ToString("F0"))%
                        </div>
                        <div class="metric-threshold">Target ≥ 70%</div>
                    </div>
                </div>

                <div class="metric-card surface-card">
                    <div class="metric-status-bar @GetMetricStatus("hallucination", latestReport.Metrics.HallucinationRate)"></div>
                    <div class="metric-icon">
                        <FluentIcon Value="@(new Icons.Regular.Size24.Warning())" />
                    </div>
                    <div class="metric-content">
                        <div class="metric-label">Hallucination Rate</div>
                        <div class="metric-value @GetMetricStatus("hallucination", latestReport.Metrics.HallucinationRate)">
                            @((latestReport.Metrics.HallucinationRate * 100).ToString("F0"))%
                        </div>
                        <div class="metric-threshold">Target ≤ 10%</div>
                    </div>
                </div>

                <div class="metric-card surface-card">
                    <div class="metric-status-bar @GetMetricStatus("avglatency", latestReport.Metrics.AvgLatencyMs)"></div>
                    <div class="metric-icon">
                        <FluentIcon Value="@(new Icons.Regular.Size24.Clock())" />
                    </div>
                    <div class="metric-content">
                        <div class="metric-label">Avg Latency</div>
                        <div class="metric-value @GetMetricStatus("avglatency", latestReport.Metrics.AvgLatencyMs)">
                            @((latestReport.Metrics.AvgLatencyMs / 1000.0).ToString("F1"))s
                        </div>
                        <div class="metric-threshold">Target ≤ 5s</div>
                    </div>
                </div>

                <div class="metric-card surface-card">
                    <div class="metric-status-bar @GetMetricStatus("p95latency", latestReport.Metrics.P95LatencyMs)"></div>
                    <div class="metric-icon">
                        <FluentIcon Value="@(new Icons.Regular.Size24.Timer())" />
                    </div>
                    <div class="metric-content">
                        <div class="metric-label">P95 Latency</div>
                        <div class="metric-value @GetMetricStatus("p95latency", latestReport.Metrics.P95LatencyMs)">
                            @((latestReport.Metrics.P95LatencyMs / 1000.0).ToString("F1"))s
                        </div>
                        <div class="metric-threshold">Target ≤ 8s</div>
                    </div>
                </div>

            </div>
        </div>
    }
</div>
